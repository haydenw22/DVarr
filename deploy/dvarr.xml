<?xml version="1.0"?>
<!-- Unraid Community Apps template for DVarr (built locally on the server: `docker build -t dvarr:latest .`) -->
<Container version="2">
  <Name>DVarr</Name>
  <Repository>dvarr:latest</Repository>
  <Registry/>
  <Network>bridge</Network>
  <MyIP/>
  <Shell>sh</Shell>
  <Privileged>false</Privileged>
  <Support/>
  <Project/>
  <Overview>DVarr — reliability-first, self-hosted IPTV sports DVR. Records directly from the provider through its own per-credential tuner pool (one stream per login), with a supervised segmented recorder that relaunches on stall and never misses a can't-miss event. Replaces the previous DVR.</Overview>
  <Category>MediaApp:Video</Category>
  <WebUI>http://[IP]:[PORT:1867]/</WebUI>
  <TemplateURL/>
  <Icon/>
  <ExtraParams>--runtime=nvidia</ExtraParams>
  <!-- NVENC drives the live-preview transcode (NVDEC decode + scale_cuda + h264_nvenc) so previewing HEVC/4K
       channels doesn't peg the CPU. Needs the Unraid Nvidia Driver plugin + the NVIDIA_* vars below. Recording
       capture itself is -c copy (no GPU). Runs fine alongside Plex's NVENC on driver 580 (no single-session limit). -->
  <PostArgs/>
  <CPUset/>
  <DateInstalled/>
  <DonateText/>
  <DonateLink/>
  <Description>DVarr — reliability-first IPTV sports DVR. WebUI on 1867. Reference other containers (Plex, Home Assistant, Prowlarr) by 192.168.4.63:&lt;port&gt;, never localhost/172.17.x.x.</Description>
  <Networking>
    <Mode>bridge</Mode>
    <Publish>
      <Port>
        <HostPort>1867</HostPort>
        <ContainerPort>1867</ContainerPort>
        <Protocol>tcp</Protocol>
      </Port>
    </Publish>
  </Networking>
  <Data>
    <Volume>
      <HostDir>/mnt/user/appdata/dvarr</HostDir>
      <ContainerDir>/config</ContainerDir>
      <Mode>rw</Mode>
    </Volume>
    <Volume>
      <HostDir>/mnt/user/Media/Sports</HostDir>
      <ContainerDir>/media</ContainerDir>
      <Mode>rw</Mode>
    </Volume>
    <!-- In-flight TS segments. Point at a fast SSD cache pool if available (open decision D33);
         defaults to appdata so it works out of the box. -->
    <Volume>
      <HostDir>/mnt/user/appdata/dvarr/segments</HostDir>
      <ContainerDir>/segments</ContainerDir>
      <Mode>rw</Mode>
    </Volume>
  </Data>
  <Environment>
    <Variable>
      <Name>TZ</Name>
      <Value>Australia/Brisbane</Value>
      <Mode/>
    </Variable>
    <Variable>
      <Name>NVIDIA_VISIBLE_DEVICES</Name>
      <Value>0000:01:00.0</Value>
      <Mode/>
    </Variable>
    <Variable>
      <Name>NVIDIA_DRIVER_CAPABILITIES</Name>
      <Value>compute,video,utility</Value>
      <Mode/>
    </Variable>
  </Environment>
  <Config Name="WebUI Port" Target="1867" Default="1867" Mode="tcp" Description="DVarr web UI / API" Type="Port" Display="always" Required="true" Mask="false">1867</Config>
  <Config Name="Appdata (/config)" Target="/config" Default="/mnt/user/appdata/dvarr" Mode="rw" Description="DB (SQLite WAL), settings, logs" Type="Path" Display="always" Required="true" Mask="false">/mnt/user/appdata/dvarr</Config>
  <Config Name="Media (/media)" Target="/media" Default="/mnt/user/Media/Sports" Mode="rw" Description="Finished recordings (dedicated Sports library)" Type="Path" Display="always" Required="true" Mask="false">/mnt/user/Media/Sports</Config>
  <Config Name="Segments (/segments)" Target="/segments" Default="/mnt/user/appdata/dvarr/segments" Mode="rw" Description="In-flight TS segment scratch (prefer an SSD cache pool)" Type="Path" Display="always" Required="true" Mask="false">/mnt/user/appdata/dvarr/segments</Config>
  <Config Name="TZ" Target="TZ" Default="Australia/Brisbane" Mode="" Description="Display timezone (storage is UTC epoch regardless)" Type="Variable" Display="always" Required="false" Mask="false">Australia/Brisbane</Config>
  <Config Name="NVIDIA GPU (PCI id)" Target="NVIDIA_VISIBLE_DEVICES" Default="all" Mode="" Description="GPU for the live-preview NVENC transcode. Use the card's PCI id (e.g. 0000:01:00.0) or 'all'. Requires ExtraParams=--runtime=nvidia + the Nvidia Driver plugin." Type="Variable" Display="advanced" Required="false" Mask="false">0000:01:00.0</Config>
  <Config Name="NVIDIA caps" Target="NVIDIA_DRIVER_CAPABILITIES" Default="compute,video,utility" Mode="" Description="'video' = NVENC/NVDEC, 'compute' = CUDA (scale_cuda)." Type="Variable" Display="advanced" Required="false" Mask="false">compute,video,utility</Config>
</Container>
