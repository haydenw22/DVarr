<Project Sdk="Microsoft.NET.Sdk.Web">

  <PropertyGroup>
    <TargetFramework>net8.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <RootNamespace>DVarr</RootNamespace>
    <AssemblyName>DVarr</AssemblyName>
    <!-- SemVer (see CHANGELOG.md). MAJOR=generational leap (still 1), MINOR=new functionality/major fixes,
         PATCH=minor fixes/polish. Surfaced on /api/health and the UI. Bump this with every CHANGELOG entry. -->
    <Version>1.16.0</Version>
    <!-- Brisbane is a fixed UTC+10 (no DST); we never rely on OS tz data, so invariant globalization is safe and keeps the container slim. -->
    <InvariantGlobalization>true</InvariantGlobalization>
    <TreatWarningsAsErrors>false</TreatWarningsAsErrors>
  </PropertyGroup>

  <ItemGroup>
    <!-- Copy the web UI into the output dir so it's served when the built DLL runs
         (and in the Docker publish output) regardless of the working directory. -->
    <Content Update="wwwroot\**\*" CopyToOutputDirectory="PreserveNewest" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.EntityFrameworkCore.Sqlite" Version="8.0.10" />
    <PackageReference Include="Microsoft.EntityFrameworkCore.Design" Version="8.0.10">
      <PrivateAssets>all</PrivateAssets>
      <IncludeAssets>runtime; build; native; contentfiles; analyzers; buildtransitive</IncludeAssets>
    </PackageReference>
  </ItemGroup>

</Project>
